# Copia este archivo como .env y rellena los valores:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (macOS / Linux)

# Clave de API de OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=tu-clave-aqui

# Puerto del servidor (opcional; si no se define, se usa 3000)
# PORT=3000

# ElevenLabs — respuesta en voz cuando el usuario envía audio (https://elevenlabs.io)
# ELEVENLABS_VOICE_ID=VmejBeYhbrcTPwDniox7
# ELEVENLABS_API_KEY=tu_api_key_elevenlabs

# Historial de chat (SQLite). Por defecto: ./data/conversations.sqlite (carpeta ignorada por git)
# CHAT_DB_PATH=L:/ChatBotAmarte/data/conversations.sqlite

# Memoria operativa Markdown para el prompt de Martina (opcional; por defecto: ./config/memoria.md)
# MARTINA_MEMORIA_PATH=L:/ChatBotAmarte/config/memoria.local.md
